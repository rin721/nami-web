---
import '@nami/themes/default.css';
import '@nami/themes/ant-illustration.css';
import '../styles.css';
import { ClientRouter } from 'astro:transitions';
import { Blocks, BookOpen, Home, Palette, Rocket, SlidersHorizontal } from '@lucide/astro';
import { docsLocales, localizedPath, logicalPathFromUrl, t, type DocsLocale } from '../lib/site';

interface Props {
  locale: DocsLocale;
  title?: string;
  description?: string;
}

const { locale, title = 'Nami UI', description = t(locale, 'site.description') } = Astro.props;
const logicalPath = logicalPathFromUrl(Astro.url.pathname, locale);
const primary = [
  { path: '/', label: t(locale, 'nav.home'), Icon: Home },
  { path: '/docs/getting-started/', label: t(locale, 'nav.getStarted'), Icon: Rocket },
  { path: '/components/', label: t(locale, 'nav.components'), Icon: Blocks },
  { path: '/theme/', label: t(locale, 'nav.theme'), Icon: Palette },
  { path: '/playground/theme-designer/', label: t(locale, 'nav.playground'), Icon: SlidersHorizontal },
  { path: '/resources/quality/', label: t(locale, 'nav.resources'), Icon: BookOpen }
];

function isActive(path: string) {
  if (path === '/') return logicalPath === '/';
  return logicalPath.startsWith(path);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Nami UI' ? t(locale, 'site.title') : `${title} · Nami UI`}</title>
    <script>
      import '../scripts/register-nami.ts';
    </script>
    <ClientRouter />
  </head>
  <body>
    <nami-config id="docs-config" locale={locale} dir="ltr">
      <nami-theme id="docs-theme" theme="light" density="comfortable" motion="normal" style-preset="default" radius="round" contrast="normal" accent="#3b82f6">
        <nami-app-shell>
          <nav slot="rail" class="rail-stack" aria-label="Primary">
            {primary.map((link) => {
              const Icon = link.Icon;
              return (
                <a href={localizedPath(locale, link.path)} aria-current={isActive(link.path) ? 'page' : 'false'} aria-label={link.label} title={link.label} data-label={link.label}>
                  <span class="rail-icon" aria-hidden="true"><Icon size={20} stroke-width={2.2} /></span>
                </a>
              );
            })}
          </nav>
          <div slot="top" class="mobile-bar">
            <a class="brand-link" href={localizedPath(locale, '/')}>Nami UI</a>
            <nami-icon-button id="docs-toggle-theme" label="Toggle theme"><span slot="icon">T</span></nami-icon-button>
          </div>
          <nav slot="bottom" class="bottom-nav" aria-label="Mobile">
            {[primary[0], primary[1], primary[2], primary[3]].map((link) => (
              <a href={localizedPath(locale, link.path)} aria-current={isActive(link.path) ? 'page' : 'false'}>
                {link.label}
              </a>
            ))}
          </nav>
          <main class="docs-page">
            <slot />
          </main>
        </nami-app-shell>
        <nami-drawer id="docs-theme-drawer" placement="right">
          <h2 slot="label">{t(locale, 'controls.theme')}</h2>
          <div class="control-stack">
            <nami-tab-bar data-locale-mode value={locale}>
              {docsLocales.map((item) => <button value={item}>{item === 'zh-CN' ? '中文' : 'English'}</button>)}
            </nami-tab-bar>
            <nami-tab-bar data-theme-mode value="light">
              <button value="light">{t(locale, 'controls.light')}</button>
              <button value="dark">{t(locale, 'controls.dark')}</button>
            </nami-tab-bar>
            <div class="swatches" aria-label="Accent">
              <button data-accent="#3b82f6" style="--swatch: #3b82f6">{t(locale, 'controls.blue')}</button>
              <button data-accent="#14b8a6" style="--swatch: #14b8a6">{t(locale, 'controls.teal')}</button>
              <button data-accent="#8b5cf6" style="--swatch: #8b5cf6">{t(locale, 'controls.violet')}</button>
            </div>
            <nami-chip data-density-toggle checkbox value="compact">{t(locale, 'controls.compact')}</nami-chip>
            <nami-switch data-motion-toggle>{t(locale, 'controls.reduced')}</nami-switch>
            <nami-chip data-style-toggle checkbox value="illustration">{t(locale, 'controls.illustration')}</nami-chip>
            <nami-tab-bar data-radius-mode value="round">
              <button value="sharp">{t(locale, 'controls.radiusSharp')}</button>
              <button value="soft">{t(locale, 'controls.radiusSoft')}</button>
              <button value="round">{t(locale, 'controls.radiusRound')}</button>
            </nami-tab-bar>
            <nami-chip data-contrast-toggle checkbox value="high">{t(locale, 'controls.highContrast')}</nami-chip>
            <nami-input label="Search" placeholder="Pagefind"></nami-input>
          </div>
        </nami-drawer>
      </nami-theme>
    </nami-config>
    <script is:inline>
      const hash = window.location.hash.replace(/^#/, '');
      if (hash.startsWith('/')) {
        let normalized = hash.endsWith('/') ? hash : `${hash}/`;
        if (!/^\/(zh-CN|en-US)(\/|$)/.test(normalized)) normalized = `/zh-CN${normalized}`;
        window.location.replace(normalized);
      }
    </script>
  </body>
</html>
