---
import '../../../../packages/core/src/critical.css';
import '../../../../packages/themes/src/default.css';
import '../../../../packages/themes/src/ant-illustration.css';
import '../styles.css';
import { ClientRouter } from 'astro:transitions';
import { Blocks, BookOpen, Home, Palette, Rocket, Settings } from '@lucide/astro';
import NamiMark from './NamiMark.astro';
import { docsSections } from '../lib/docs-structure';
import { docsLocales, localizedPath, logicalPathFromUrl, t, type DocsLocale } from '../lib/site';

interface Props {
  locale: DocsLocale;
  title?: string;
  description?: string;
}

const { locale, title = 'Nami UI', description = t(locale, 'site.description') } = Astro.props;
const logicalPath = logicalPathFromUrl(Astro.url.pathname, locale);
const primary = [
  { path: '/', activePath: '/', label: t(locale, 'nav.home'), Icon: Home },
  { path: docsSections.start.path, activePath: '/docs/', label: t(locale, 'nav.getStarted'), Icon: Rocket },
  { path: '/components/', activePath: '/components/', label: t(locale, 'nav.components'), Icon: Blocks },
  { path: docsSections.theme.path, activePath: '/theme/', label: t(locale, 'nav.theme'), Icon: Palette },
  { path: docsSections.resources.path, activePath: '/resources/', label: t(locale, 'nav.resources'), Icon: BookOpen }
];
const settingsLink = { path: '/settings/appearance/', label: t(locale, 'nav.settings') };

function isActive(path: string) {
  if (path === '/') return logicalPath === '/';
  return logicalPath.startsWith(path);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/brand/nami-app-icon.svg" />
    <link rel="mask-icon" href="/brand/nami-mask-icon.svg" color="#0b2a6f" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:title" content={title === 'Nami UI' ? t(locale, 'site.title') : `${title} | Nami UI`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/brand/nami-logo.svg" />
    <meta name="twitter:card" content="summary" />
    <title>{title === 'Nami UI' ? t(locale, 'site.title') : `${title} | Nami UI`}</title>
    <script>
      import '../scripts/register-nami.ts';
    </script>
    <ClientRouter />
  </head>
  <body>
    <nami-config id="docs-config" locale={locale} dir="ltr">
      <nami-theme id="docs-theme" theme="light" density="comfortable" size="md" motion="normal" style-preset="default" radius="round" contrast="normal" accent="#3b82f6">
        <nami-top-progress id="docs-top-progress" appear="true" appear-duration="360" transition:persist="docs-top-progress"></nami-top-progress>
        <nami-scroll-smoother id="docs-scroll-smoother" preset="balanced" duration="1.2" touch-multiplier="2" anchors stop-inertia-on-navigate transition:persist="docs-scroll-smoother"></nami-scroll-smoother>
        <nami-page-transition id="docs-page-transition" appearance="veil" active transition:persist="docs-page-transition">
          <span data-nami-transition-fallback>
            <NamiMark />
            <span aria-hidden="true"></span>
          </span>
        </nami-page-transition>
        <nami-app-shell>
          <nav slot="rail" class="rail-stack" aria-label="Primary">
            <div class="rail-primary">
              {primary.map((link) => {
                const Icon = link.Icon;
                return (
                    <a href={localizedPath(locale, link.path)} aria-current={isActive(link.activePath) ? 'page' : 'false'} aria-label={link.label} title={link.label} data-label={link.label}>
                    <span class="rail-icon" aria-hidden="true"><Icon size={20} stroke-width={2.2} /></span>
                  </a>
                );
              })}
            </div>
            <div class="rail-secondary">
              <a href={localizedPath(locale, settingsLink.path)} aria-current={isActive('/settings/') ? 'page' : 'false'} aria-label={settingsLink.label} title={settingsLink.label} data-label={settingsLink.label}>
                <span class="rail-icon" aria-hidden="true"><Settings size={20} stroke-width={2.2} /></span>
              </a>
            </div>
          </nav>
          <div slot="top" class="mobile-bar">
            <a class="brand-link" href={localizedPath(locale, '/')}>
              <NamiMark class="brand-mark" />
              <span>Nami UI</span>
            </a>
            <div class="mobile-actions">
              <a class="mobile-settings-link" href={localizedPath(locale, settingsLink.path)} aria-label={settingsLink.label} title={settingsLink.label}>
                <Settings size={18} stroke-width={2.2} />
              </a>
              <nami-icon-button id="docs-toggle-theme" label="Toggle theme"><span slot="icon">T</span></nami-icon-button>
            </div>
          </div>
          <nav slot="bottom" class="bottom-nav" aria-label="Mobile">
            {primary.map((link) => (
              <a href={localizedPath(locale, link.path)} aria-current={isActive(link.activePath) ? 'page' : 'false'}>
                {link.label}
              </a>
            ))}
          </nav>
          <main class="docs-page">
            <slot />
          </main>
        </nami-app-shell>
        <nami-drawer id="docs-theme-drawer" placement="right">
          <h2 slot="label">{t(locale, 'controls.theme')}</h2>
          <div class="control-stack">
            <nami-tab-bar data-locale-mode value={locale}>
              {docsLocales.map((item) => <button value={item}>{item === 'zh-CN' ? '中文' : 'English'}</button>)}
            </nami-tab-bar>
            <nami-tab-bar data-theme-mode value="light">
              <button value="light">{t(locale, 'controls.light')}</button>
              <button value="dark">{t(locale, 'controls.dark')}</button>
            </nami-tab-bar>
            <div class="swatches" aria-label="Accent">
              <button data-accent="#3b82f6" style="--swatch: #3b82f6">{t(locale, 'controls.blue')}</button>
              <button data-accent="#14b8a6" style="--swatch: #14b8a6">{t(locale, 'controls.teal')}</button>
              <button data-accent="#8b5cf6" style="--swatch: #8b5cf6">{t(locale, 'controls.violet')}</button>
            </div>
            <nami-chip data-density-toggle checkbox value="compact">{t(locale, 'controls.compact')}</nami-chip>
            <nami-tab-bar data-size-mode value="md">
              <button value="sm">S</button>
              <button value="md">M</button>
              <button value="lg">L</button>
            </nami-tab-bar>
            <nami-switch data-motion-toggle>{t(locale, 'controls.reduced')}</nami-switch>
            <nami-chip data-style-toggle checkbox value="illustration">{t(locale, 'controls.illustration')}</nami-chip>
            <nami-tab-bar data-radius-mode value="round">
              <button value="sharp">{t(locale, 'controls.radiusSharp')}</button>
              <button value="soft">{t(locale, 'controls.radiusSoft')}</button>
              <button value="round">{t(locale, 'controls.radiusRound')}</button>
            </nami-tab-bar>
            <nami-chip data-contrast-toggle checkbox value="high">{t(locale, 'controls.highContrast')}</nami-chip>
            <nami-input label="Search" placeholder="Pagefind"></nami-input>
          </div>
        </nami-drawer>
      </nami-theme>
    </nami-config>
    <script is:inline>
      const hash = window.location.hash.replace(/^#/, '');
      if (hash.startsWith('/')) {
        let normalized = hash.endsWith('/') ? hash : `${hash}/`;
        if (!/^\/(zh-CN|en-US)(\/|$)/.test(normalized)) normalized = `/zh-CN${normalized}`;
        window.location.replace(normalized);
      }
    </script>
  </body>
</html>
