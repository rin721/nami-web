---
import DocsLayout from './DocsLayout.astro';
import { projectInfo } from '../lib/project';
import { docsLocales, localizedPath, t, type DocsLocale } from '../lib/site';

type SettingsSection = 'appearance' | 'transition' | 'language' | 'preferences' | 'config' | 'experimental' | 'about';

interface Props {
  locale: DocsLocale;
  section: SettingsSection;
}

const { locale, section } = Astro.props;

const sectionDescriptions: Record<SettingsSection, string> = locale === 'zh-CN'
  ? {
      appearance: '主题、主色、风格、密度、尺寸和组件形态。',
      transition: '首屏揭幕、路由顶部进度和过渡动效。',
      language: '切换文档语言并保留当前路径。',
      preferences: '阅读、状态保留和代码示例偏好。',
      config: '导出当前主题的 CSS、DTCG JSON 和 TS theme config。',
      experimental: '可逆、可测试的候选能力。',
      about: '版本、贡献者、赞助商状态和包入口。'
    }
  : {
      appearance: 'Theme, primary color, style, density, size, and component shape.',
      transition: 'First-paint reveal, route progress, and transition motion.',
      language: 'Switch docs language while keeping the current path.',
      preferences: 'Reading, persistence, and code example preferences.',
      config: 'Export current theme CSS, DTCG JSON, and TS theme config.',
      experimental: 'Reversible and testable candidate features.',
      about: 'Version, contributors, sponsor status, and package entry points.'
    };

const sections: Array<{ id: SettingsSection; label: string; description: string }> = [
  { id: 'appearance', label: t(locale, 'settings.appearance'), description: sectionDescriptions.appearance },
  { id: 'transition', label: t(locale, 'settings.transition'), description: sectionDescriptions.transition },
  { id: 'language', label: t(locale, 'settings.language'), description: sectionDescriptions.language },
  { id: 'preferences', label: t(locale, 'settings.preferences'), description: sectionDescriptions.preferences },
  { id: 'config', label: t(locale, 'settings.config'), description: sectionDescriptions.config },
  { id: 'experimental', label: t(locale, 'settings.experimental'), description: sectionDescriptions.experimental },
  { id: 'about', label: t(locale, 'settings.about'), description: sectionDescriptions.about }
];

const current = sections.find((item) => item.id === section) ?? sections[0];
const showRouteBar = locale === 'zh-CN' ? '显示路由顶部进度条' : 'Show route progress bar';
const keepVisualSettings = locale === 'zh-CN' ? '刷新后保留当前视觉设置' : 'Keep visual settings after reload';
const compactDocs = locale === 'zh-CN' ? '降低文档区块间距' : 'Reduce docs spacing';
const primaryContributor = projectInfo.contributors[0];
---

<DocsLayout locale={locale} title={`${current.label} - ${t(locale, 'settings.title')}`}>
  <section class="section settings-shell">
    <aside class="settings-nav" aria-label={t(locale, 'settings.title')}>
      <div class="settings-nav-header">
        <p class="eyebrow">{t(locale, 'settings.title')}</p>
        <h1>{t(locale, 'settings.title')}</h1>
        <p>{t(locale, 'settings.copy')}</p>
      </div>
      <nav class="settings-section-list">
        {sections.map((item) => (
          <a href={localizedPath(locale, `/settings/${item.id}/`)} aria-current={item.id === section ? 'page' : 'false'}>
            <strong>{item.label}</strong>
            <span>{item.description}</span>
          </a>
        ))}
      </nav>
    </aside>

    <div class="settings-content">
      <div class="section-heading settings-heading">
        <p class="eyebrow">{current.label}</p>
        <h2>{current.label}</h2>
        <p>{current.description}</p>
      </div>

      {section === 'appearance' && (
        <div class="settings-grid">
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.scheme')}</h3>
            <nami-tab-bar data-theme-mode value="light">
              <button value="light">{t(locale, 'controls.light')}</button>
              <button value="dark">{t(locale, 'controls.dark')}</button>
            </nami-tab-bar>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.palette')}</h3>
            <div class="swatches" aria-label={t(locale, 'settings.palette')}>
              <button data-accent="#3b82f6" style="--swatch: #3b82f6">{t(locale, 'controls.blue')}</button>
              <button data-accent="#14b8a6" style="--swatch: #14b8a6">{t(locale, 'controls.teal')}</button>
              <button data-accent="#8b5cf6" style="--swatch: #8b5cf6">{t(locale, 'controls.violet')}</button>
            </div>
            <label class="color-field">
              <span>{t(locale, 'settings.customPalette')}</span>
              <input data-accent-input type="color" value="#3b82f6" />
            </label>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.style')}</h3>
            <nami-tab-bar data-style-preset-mode value="default">
              <button value="default">Default</button>
              <button value="illustration">{t(locale, 'controls.illustration')}</button>
            </nami-tab-bar>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.shape')}</h3>
            <nami-tab-bar data-density-mode value="comfortable">
              <button value="comfortable">Comfortable</button>
              <button value="compact">{t(locale, 'controls.compact')}</button>
            </nami-tab-bar>
            <nami-tab-bar data-size-mode value="md">
              <button value="sm">Small</button>
              <button value="md">Default</button>
              <button value="lg">Large</button>
            </nami-tab-bar>
            <nami-tab-bar data-radius-mode value="round">
              <button value="sharp">{t(locale, 'controls.radiusSharp')}</button>
              <button value="soft">{t(locale, 'controls.radiusSoft')}</button>
              <button value="round">{t(locale, 'controls.radiusRound')}</button>
            </nami-tab-bar>
            <nami-tab-bar data-contrast-mode value="normal">
              <button value="normal">Normal</button>
              <button value="high">{t(locale, 'controls.highContrast')}</button>
            </nami-tab-bar>
          </nami-card>
        </div>
      )}

      {section === 'transition' && (
        <div class="settings-grid">
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.firstLoad')}</h3>
            <nami-tab-bar data-initial-transition-mode value="veil">
              <button value="veil">Veil</button>
              <button value="panel">Panel</button>
              <button value="none">None</button>
            </nami-tab-bar>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.routeProgress')}</h3>
            <nami-switch data-route-bar-toggle checked>{showRouteBar}</nami-switch>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.barHeight')}</h3>
            <nami-input
              data-progress-height-input
              type="number"
              value="4"
              label={locale === 'zh-CN' ? '进度高度（px）' : 'Progress height (px)'}
              helper-text={locale === 'zh-CN' ? '2-16px；首屏揭幕与路由顶部进度共用。' : '2-16px; shared by first reveal and route progress.'}
            ></nami-input>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.progressEffect')}</h3>
            <nami-tab-bar data-progress-effect-mode value="flow">
              <button value="flow">{locale === 'zh-CN' ? '柔和流动' : 'Soft flow'}</button>
              <button value="slide">{locale === 'zh-CN' ? '极简滑动' : 'Clean slide'}</button>
              <button value="pulse">{locale === 'zh-CN' ? '脉冲呼吸' : 'Pulse'}</button>
            </nami-tab-bar>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.progressDuration')}</h3>
            <nami-input
              data-progress-duration-input
              type="number"
              value="260"
              label={locale === 'zh-CN' ? '动画时长（ms）' : 'Animation duration (ms)'}
              helper-text={locale === 'zh-CN' ? '80-1200ms；影响填充、显示与隐藏的柔和程度。' : '80-1200ms; controls the softness of fill, enter, and exit.'}
            ></nami-input>
          </nami-card>
          <nami-card class="settings-preview-card">
            <h3 slot="header">{t(locale, 'settings.preview')}</h3>
            <div class="settings-transition-preview">
              <nami-top-progress data-docs-top-progress-preview active variant="inline" progress="68" height="4" duration="260" effect="flow"></nami-top-progress>
            </div>
            <p>{locale === 'zh-CN' ? '轨道与填充保持同高；动作、时长和高度会同步到真实路由进度。' : 'Track and fill share the same height; effect, duration, and height sync to real route progress.'}</p>
          </nami-card>
        </div>
      )}

      {section === 'language' && (
        <div class="settings-grid">
          <nami-card>
            <h3 slot="header">{t(locale, 'controls.locale')}</h3>
            <nami-tab-bar data-locale-mode value={locale}>
              {docsLocales.map((item) => <button value={item}>{item === 'zh-CN' ? '中文' : 'English'}</button>)}
            </nami-tab-bar>
          </nami-card>
        </div>
      )}

      {section === 'preferences' && (
        <div class="settings-grid">
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.rememberTheme')}</h3>
            <nami-switch data-remember-theme-toggle checked>{keepVisualSettings}</nami-switch>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.compactDocs')}</h3>
            <nami-switch data-compact-docs-toggle>{compactDocs}</nami-switch>
          </nami-card>
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.codeExamples')}</h3>
            <nami-tab-bar data-code-example-mode value="html">
              <button value="html">HTML</button>
              <button value="vue">Vue</button>
              <button value="react">React</button>
            </nami-tab-bar>
          </nami-card>
        </div>
      )}

      {section === 'config' && (
        <nami-docs-theme-designer class="settings-export-grid">
          <nami-card>
            <h3 slot="header">CSS Variables</h3>
            <nami-docs-code-block data-generated-css data-language="css"></nami-docs-code-block>
          </nami-card>
          <nami-card>
            <h3 slot="header">DTCG JSON</h3>
            <nami-docs-code-block data-generated-json data-language="json"></nami-docs-code-block>
          </nami-card>
          <nami-card>
            <h3 slot="header">TypeScript Config</h3>
            <nami-docs-code-block data-generated-ts data-language="ts"></nami-docs-code-block>
          </nami-card>
          <nami-card>
            <h3 slot="header">{locale === 'zh-CN' ? '诊断' : 'Diagnostics'}</h3>
            <div class="designer-diagnostics" data-theme-diagnostics></div>
          </nami-card>
        </nami-docs-theme-designer>
      )}

      {section === 'experimental' && (
        <div class="settings-grid">
          <nami-card>
            <h3 slot="header">{t(locale, 'settings.experimental')}</h3>
            <p>{t(locale, 'settings.experimentalCopy')}</p>
            <nami-badge variant="warning" tone="soft">{locale === 'zh-CN' ? '暂无破坏性开关' : 'No destructive toggles'}</nami-badge>
          </nami-card>
        </div>
      )}

      {section === 'about' && (
        <div class="settings-grid">
          <nami-card>
            <h3 slot="header">Nami UI</h3>
            <p>{t(locale, 'settings.aboutCopy')}</p>
            <dl>
              <dt>Package</dt>
              <dd><code>{projectInfo.packageName}</code></dd>
              <dt>Theme CSS</dt>
              <dd><code>{projectInfo.themeCss}</code></dd>
              <dt>Version</dt>
              <dd><code>{projectInfo.version}</code></dd>
            </dl>
          </nami-card>
          <nami-card>
            <h3 slot="header">{locale === 'zh-CN' ? '贡献者' : 'Contributors'}</h3>
            <p><a href={primaryContributor.url} target="_blank" rel="noreferrer"><strong>{primaryContributor.name}</strong></a></p>
          </nami-card>
          <nami-card>
            <h3 slot="header">{locale === 'zh-CN' ? '仓库' : 'Repository'}</h3>
            <p><a href={projectInfo.repositoryUrl} target="_blank" rel="noreferrer">{projectInfo.repositoryLabel}</a></p>
          </nami-card>
          <nami-card>
            <h3 slot="header">{locale === 'zh-CN' ? '赞助商' : 'Sponsors'}</h3>
            <p>{projectInfo.sponsorStatus[locale]}</p>
          </nami-card>
        </div>
      )}
    </div>
  </section>
</DocsLayout>
