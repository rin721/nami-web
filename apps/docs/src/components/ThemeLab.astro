---
import { t, type DocsLocale } from '../lib/site';

interface Props {
  locale: DocsLocale;
}

const { locale } = Astro.props;
---

<section class="section" data-theme-lab>
  <div class="section-heading">
    <p class="eyebrow">{t(locale, 'nav.lab')}</p>
    <h2>{t(locale, 'lab.title')}</h2>
    <p>{t(locale, 'lab.copy')}</p>
  </div>
  <div class="theme-lab-grid">
    <nami-card>
      <h3 slot="header">{t(locale, 'controls.theme')}</h3>
      <div class="control-stack">
        <nami-tab-bar data-theme-mode value="light">
          <button value="light">{t(locale, 'controls.light')}</button>
          <button value="dark">{t(locale, 'controls.dark')}</button>
        </nami-tab-bar>
        <div class="swatches">
          <button data-accent="#3b82f6" style="--swatch: #3b82f6">{t(locale, 'controls.blue')}</button>
          <button data-accent="#14b8a6" style="--swatch: #14b8a6">{t(locale, 'controls.teal')}</button>
          <button data-accent="#8b5cf6" style="--swatch: #8b5cf6">{t(locale, 'controls.violet')}</button>
        </div>
        <nami-chip data-density-toggle checkbox value="compact">{t(locale, 'controls.compact')}</nami-chip>
        <nami-switch data-motion-toggle>{t(locale, 'controls.reduced')}</nami-switch>
        <nami-chip data-style-toggle checkbox value="illustration">{t(locale, 'controls.illustration')}</nami-chip>
      </div>
    </nami-card>
    <nami-card>
      <h3 slot="header">Live surface</h3>
      <div class="theme-live-surface">
        <nami-button>Primary action</nami-button>
        <nami-button variant="soft">Soft action</nami-button>
        <nami-chip checkbox selected value="active">Selected chip</nami-chip>
        <nami-switch checked>Enabled</nami-switch>
        <nami-radio-card selected label="Current skin" description="This card follows the current root theme."></nami-radio-card>
      </div>
    </nami-card>
  </div>
  <div class="theme-contract-grid">
    <section class="theme-contract-stage" data-contract-stage="default-light">
      <h3>Default light</h3>
      <div class="contract-controls"><nami-button>Primary</nami-button><nami-chip checkbox selected value="default-light">Selected</nami-chip><nami-switch checked>On</nami-switch><nami-radio-card selected label="Card" description="Light neutral tokens."></nami-radio-card><nami-button loading>Loading</nami-button></div>
    </section>
    <section class="theme-contract-stage nami-theme-dark" data-contract-stage="default-dark">
      <h3>Default dark</h3>
      <div class="contract-controls"><nami-button>Primary</nami-button><nami-chip checkbox selected value="default-dark">Selected</nami-chip><nami-switch checked>On</nami-switch><nami-radio-card selected label="Card" description="Dark neutral tokens."></nami-radio-card><nami-button loading>Loading</nami-button></div>
    </section>
    <section class="theme-contract-stage nami-theme-illustration" data-contract-stage="illustration-light">
      <h3>Illustration light</h3>
      <div class="contract-controls"><nami-button>Primary</nami-button><nami-chip checkbox selected value="illustration-light">Selected</nami-chip><nami-switch checked>On</nami-switch><nami-radio-card selected label="Paper card" description="Light hand-drawn controls."></nami-radio-card><nami-button loading>Loading</nami-button></div>
    </section>
    <section class="theme-contract-stage nami-theme-dark nami-theme-illustration" data-contract-stage="illustration-dark">
      <h3>Illustration dark</h3>
      <div class="contract-controls"><nami-button>Primary</nami-button><nami-chip checkbox selected value="illustration-dark">Selected</nami-chip><nami-switch checked>On</nami-switch><nami-radio-card selected label="Night paper card" description="Dark shell, paper controls, ink stroke."></nami-radio-card><nami-button loading>Loading</nami-button></div>
    </section>
  </div>
</section>
