---
import DocsLayout from '../../../components/DocsLayout.astro';
import { docsSections } from '../../../lib/docs-structure';
import { docsLocales, localizedPath, t, type DocsLocale } from '../../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
const section = docsSections.resources;
const introCards = locale === 'zh-CN'
  ? [
      ['这里放什么', '设计规范、质量基线、国际化策略、语义结构、更新日志和 FAQ 等工程资料。'],
      ['不放什么', '组件 API 回到 Components；主题工具和 tokens 回到 Theme；官网偏好回到 Settings。'],
      ['下一步去哪', '做视觉原则先看 Design，发版前看 Quality 和 Changelog，遇到资源或生态问题看 FAQ。']
    ]
  : [
      ['What lives here', 'Design guidance, quality baselines, i18n strategy, semantic anatomy, changelog, and FAQ.'],
      ['What stays out', 'Component APIs belong to Components. Theme tools and tokens belong to Theme. Site preferences stay in Settings.'],
      ['Where next', 'Read Design for visual principles, Quality and Changelog before release, and FAQ for resource or ecosystem status.']
    ];
---

<DocsLayout locale={locale} title={t(locale, 'resources.title')}>
  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{t(locale, 'nav.resources')}</p>
      <h1>{t(locale, 'resources.title')}</h1>
      <p>{section.description[locale]}</p>
    </div>
    <div class="entry-grid">
      {introCards.map(([title, copy]) => (
        <nami-card>
          <nami-badge slot="header" variant="primary">{title}</nami-badge>
          <p>{copy}</p>
        </nami-card>
      ))}
    </div>
    <div class="entry-grid">
      {section.entries.map((item) => (
        <nami-card>
          <nami-badge slot="header" variant="primary">{item.slug}</nami-badge>
          <h3>{item.title[locale]}</h3>
          <p>{item.description[locale]}</p>
          <nami-button variant="soft" onclick={`location.href='${localizedPath(locale, item.path)}'`}>{t(locale, 'component.open')}</nami-button>
        </nami-card>
      ))}
    </div>
  </section>
</DocsLayout>
