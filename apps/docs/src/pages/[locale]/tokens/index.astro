---
import DocsLayout from '../../../components/DocsLayout.astro';
import { namiComponentMetadata } from '../../../lib/catalog';
import { docsLocales, t, type DocsLocale } from '../../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
const tokenCount = namiComponentMetadata.reduce((count, item) => count + item.tokens.length, 0);
---

<DocsLayout locale={locale} title={t(locale, 'nav.tokens')}>
  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{t(locale, 'nav.tokens')}</p>
      <h2>{t(locale, 'tokens.title')}</h2>
      <p>{t(locale, 'tokens.copy')}</p>
    </div>
    <div class="token-pipeline">
      <nami-card><nami-badge slot="header" variant="primary">Seed</nami-badge><strong>--nami-accent-50</strong><p>Brand input, mode, radius, density, motion, contrast, and style preset.</p></nami-card>
      <nami-card><nami-badge slot="header" variant="primary">Semantic</nami-badge><strong>--nami-color-primary</strong><p>Meaning shared across components.</p></nami-card>
      <nami-card><nami-badge slot="header" variant="primary">Component</nami-badge><strong>--nami-button-bg</strong><p>Per-component override boundary.</p></nami-card>
    </div>
    <nami-card>
      <h3 slot="header">Metadata coverage</h3>
      <p>{tokenCount} token hooks are referenced by component metadata.</p>
      <nami-docs-code-block data-language="html" data-code={encodeURIComponent('<nami-theme theme="dark" accent="#14b8a6" style-preset="illustration">\\n  <nami-button>Save</nami-button>\\n</nami-theme>')}></nami-docs-code-block>
    </nami-card>
  </section>
</DocsLayout>
