---
import DocsArticleLayout from '../../../components/DocsArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { adjacentDocsEntries, docsEntry, docsSections } from '../../../lib/docs-structure';
import { normalizeDocsLocale, type DocsLocale } from '../../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('start');
  return entries.flatMap((entry) => {
    const [localeId, slug] = entry.id.replace(/\.(md|mdx)$/, '').split('/');
    const locale = normalizeDocsLocale(localeId);
    if (!locale || !slug || !docsEntry('start', slug)) return [];
    return [{ params: { locale, slug }, props: { entry, locale: locale as DocsLocale, slug } }];
  });
}

const { entry, locale, slug } = Astro.props;
const rendered = await render(entry);
const { Content, headings } = rendered;
const structure = docsEntry('start', slug);

if (!structure) {
  throw new Error(`Unknown start entry: ${slug}`);
}

const adjacent = adjacentDocsEntries('start', slug);
const navGroups = [{
  title: docsSections.start.title[locale],
  items: docsSections.start.entries.map((item) => ({
    label: item.title[locale],
    href: item.path,
    description: item.description[locale]
  }))
}];
---

<DocsArticleLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.description ?? structure.description[locale]}
  eyebrow={docsSections.start.title[locale]}
  currentPath={structure.path}
  navGroups={navGroups}
  headings={headings}
  previous={adjacent.previous && { label: adjacent.previous.title[locale], href: adjacent.previous.path }}
  next={adjacent.next && { label: adjacent.next.title[locale], href: adjacent.next.path }}
>
  <Content />
</DocsArticleLayout>
