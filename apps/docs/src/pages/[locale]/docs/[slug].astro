---
import DocsLayout from '../../../components/DocsLayout.astro';
import { getCollection, render } from 'astro:content';
import { docsEntry } from '../../../lib/docs-structure';
import { normalizeDocsLocale, type DocsLocale } from '../../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('start');
  return entries.flatMap((entry) => {
    const [localeId, slug] = entry.id.replace(/\.(md|mdx)$/, '').split('/');
    const locale = normalizeDocsLocale(localeId);
    if (!locale || !slug || !docsEntry('start', slug)) return [];
    return [{
      params: { locale, slug },
      props: {
        entry,
        locale: locale as DocsLocale,
        slug
      }
    }];
  });
}

const { entry, locale, slug } = Astro.props;
const { Content } = await render(entry);
const structure = docsEntry('start', slug);
---

<DocsLayout locale={locale} title={entry.data.title} description={entry.data.description}>
  <section class="section markdown-route">
    <div class="section-heading">
      <p class="eyebrow">{structure?.title[locale] ?? entry.data.group}</p>
      <h2>{entry.data.title}</h2>
      {structure && <p>{structure.description[locale]}</p>}
    </div>
    <article id={`doc-${slug}`} class="markdown-page">
      <Content />
    </article>
  </section>
</DocsLayout>
