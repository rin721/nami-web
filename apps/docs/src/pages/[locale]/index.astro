---
import DocsLayout from '../../components/DocsLayout.astro';
import { docsLocales, localizedPath, t, type DocsLocale } from '../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
---

<DocsLayout locale={locale} title="Rin UI">
  <section class="hero product-hero" data-product-hero>
    <div class="hero-copy">
      <p class="eyebrow">{t(locale, 'home.eyebrow')}</p>
      <h1>Rin UI</h1>
      <p class="hero-subtitle">{t(locale, 'home.subtitle')}</p>
      <p class="lead">{t(locale, 'home.lead')}</p>
      <div class="hero-actions">
        <rl-button onclick={`location.href='${localizedPath(locale, '/docs/getting-started/')}'`}>{t(locale, 'home.openDocs')}</rl-button>
        <rl-button variant="soft" onclick={`location.href='${localizedPath(locale, '/components/')}'`}>{t(locale, 'home.openComponents')}</rl-button>
        <rl-button variant="soft" id="docs-open-theme">{t(locale, 'controls.theme')}</rl-button>
      </div>
      <div class="hero-proof">
        <rl-badge>{t(locale, 'home.framework')}</rl-badge>
        <rl-badge>{t(locale, 'home.themeable')}</rl-badge>
        <rl-badge>{t(locale, 'home.accessible')}</rl-badge>
        <rl-badge>{t(locale, 'home.metadata')}</rl-badge>
      </div>
    </div>

    <section class="hero-showcase" aria-label="Interactive component preview">
      <div class="showcase-bar">
        <rl-tab-bar data-theme-mode value="light">
          <button value="light">{t(locale, 'controls.light')}</button>
          <button value="dark">{t(locale, 'controls.dark')}</button>
        </rl-tab-bar>
        <rl-chip data-style-toggle checkbox value="illustration">{t(locale, 'controls.illustration')}</rl-chip>
      </div>
      <div class="showcase-grid">
        <rl-card class="component-wall">
          <rl-badge slot="header" variant="primary">Live preview</rl-badge>
          <div class="preview-toolbar">
            <rl-chip checkbox selected value="token">Token</rl-chip>
            <rl-chip checkbox value="docs">Docs</rl-chip>
            <rl-icon-button label="Favorite" selected><span slot="icon">F</span></rl-icon-button>
          </div>
          <rl-input label="Search components" placeholder="button, theme, dialog" helper-text="Focus, border, and text color follow tokens.">
            <span slot="icon">/</span>
          </rl-input>
          <rl-radio-card selected label="One source, two skins" description="Default and illustration presets share the same component implementation."></rl-radio-card>
          <div class="preview-actions">
            <rl-button>Primary</rl-button>
            <rl-button variant="soft">Soft</rl-button>
            <rl-switch checked>Live</rl-switch>
          </div>
        </rl-card>
        <rl-card class="install-card">
          <rl-badge slot="header" variant="primary">{t(locale, 'home.install')}</rl-badge>
          <rin-docs-code-block data-language="bash" data-code={encodeURIComponent('npm install @rin-labs/ui @rin-labs/themes')}></rin-docs-code-block>
          <rin-docs-code-block data-language="ts" data-code={encodeURIComponent("import '@rin-labs/themes/default.css';\nimport '@rin-labs/ui/register';")}></rin-docs-code-block>
          <div class="swatches">
            <button data-accent="#3b82f6" style="--swatch: #3b82f6">{t(locale, 'controls.blue')}</button>
            <button data-accent="#14b8a6" style="--swatch: #14b8a6">{t(locale, 'controls.teal')}</button>
            <button data-accent="#8b5cf6" style="--swatch: #8b5cf6">{t(locale, 'controls.violet')}</button>
          </div>
        </rl-card>
      </div>
    </section>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Paths</p>
      <h2>{t(locale, 'home.libraryTitle')}</h2>
      <p>{t(locale, 'home.libraryCopy')}</p>
    </div>
    <div class="entry-grid">
      <rl-card>
        <rl-badge slot="header" variant="primary">01</rl-badge>
        <h3>{t(locale, 'nav.getStarted')}</h3>
        <p>{t(locale, 'home.pathStartCopy')}</p>
        <rl-button variant="soft" onclick={`location.href='${localizedPath(locale, '/docs/getting-started/')}'`}>{t(locale, 'home.openDocs')}</rl-button>
      </rl-card>
      <rl-card>
        <rl-badge slot="header" variant="primary">02</rl-badge>
        <h3>{t(locale, 'nav.components')}</h3>
        <p>{t(locale, 'home.pathComponentsCopy')}</p>
        <rl-button variant="soft" onclick={`location.href='${localizedPath(locale, '/components/')}'`}>{t(locale, 'home.openComponents')}</rl-button>
      </rl-card>
      <rl-card>
        <rl-badge slot="header" variant="primary">03</rl-badge>
        <h3>{t(locale, 'nav.theme')}</h3>
        <p>{t(locale, 'home.pathThemeCopy')}</p>
        <rl-button variant="soft" onclick={`location.href='${localizedPath(locale, '/theme/')}'`}>{t(locale, 'nav.theme')}</rl-button>
      </rl-card>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{t(locale, 'nav.theme')}</p>
      <h2>{t(locale, 'home.vibeTitle')}</h2>
      <p>{t(locale, 'home.vibeCopy')}</p>
    </div>
    <div class="style-split">
      <div class="theme-contract-stage" data-rl-theme="light" data-rl-style="default">
        <h3>Default</h3>
        <rl-button>Save</rl-button>
        <rl-chip selected>Selected</rl-chip>
        <rl-input label="Project" placeholder="Rin UI"></rl-input>
      </div>
      <div class="theme-contract-stage rl-theme-illustration" data-rl-theme="light" data-rl-style="illustration">
        <h3>Illustration</h3>
        <rl-button>Save</rl-button>
        <rl-chip selected>Selected</rl-chip>
        <rl-input label="Project" placeholder="Rin UI"></rl-input>
      </div>
    </div>
  </section>
</DocsLayout>
