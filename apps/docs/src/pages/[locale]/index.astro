---
import DocsLayout from '../../components/DocsLayout.astro';
import NamiMark from '../../components/NamiMark.astro';
import { projectInfo } from '../../lib/project';
import { docsLocales, localizedPath, t, type DocsLocale } from '../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
const primaryContributor = projectInfo.contributors[0];
---

<DocsLayout locale={locale} title="Nami UI">
  <section class="hero product-hero" data-product-hero>
    <div class="hero-copy">
      <p class="eyebrow">{t(locale, 'home.eyebrow')}</p>
      <h1 class="hero-title">
        <NamiMark class="hero-title-icon" />
        <span>Nami UI</span>
      </h1>
      <p class="hero-subtitle">{t(locale, 'home.subtitle')}</p>
      <p class="lead">{t(locale, 'home.lead')}</p>
      <div class="hero-actions">
        <nami-button onclick={`location.href='${localizedPath(locale, '/docs/getting-started/')}'`}>{t(locale, 'home.openDocs')}</nami-button>
        <nami-button variant="soft" onclick={`location.href='${localizedPath(locale, '/components/')}'`}>{t(locale, 'home.openComponents')}</nami-button>
        <nami-button variant="soft" id="docs-open-theme">{t(locale, 'controls.theme')}</nami-button>
      </div>
      <div class="hero-proof">
        <nami-badge>{t(locale, 'home.framework')}</nami-badge>
        <nami-badge>{t(locale, 'home.themeable')}</nami-badge>
        <nami-badge>{t(locale, 'home.accessible')}</nami-badge>
        <nami-badge>{t(locale, 'home.metadata')}</nami-badge>
      </div>
    </div>

    <section class="hero-showcase hero-install" aria-label={t(locale, 'home.install')}>
      <nami-card class="install-card">
        <nami-badge slot="header" variant="primary">{t(locale, 'home.install')}</nami-badge>
        <nami-docs-install-tabs></nami-docs-install-tabs>
        <nami-docs-code-block data-language="ts" data-code={encodeURIComponent("import '@nami-web/themes/default.css';\nimport '@nami-web/ui/register';")}></nami-docs-code-block>
        <nami-docs-code-block data-language="html" data-code={encodeURIComponent('<link rel="stylesheet" href="https://nami-web.iqwq.com/cdn/nami-ui/0.1.0/css/default.css" />\n<script src="https://nami-web.iqwq.com/cdn/nami-ui/0.1.0/nami-ui.global.js"></script>')}></nami-docs-code-block>
      </nami-card>
    </section>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Paths</p>
      <h2>{t(locale, 'home.libraryTitle')}</h2>
      <p>{t(locale, 'home.libraryCopy')}</p>
    </div>
    <div class="entry-grid">
      <nami-card>
        <nami-badge slot="header" variant="primary">01</nami-badge>
        <h3>{t(locale, 'nav.getStarted')}</h3>
        <p>{t(locale, 'home.pathStartCopy')}</p>
        <nami-button variant="soft" onclick={`location.href='${localizedPath(locale, '/docs/getting-started/')}'`}>{t(locale, 'home.openDocs')}</nami-button>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="primary">02</nami-badge>
        <h3>{t(locale, 'nav.components')}</h3>
        <p>{t(locale, 'home.pathComponentsCopy')}</p>
        <nami-button variant="soft" onclick={`location.href='${localizedPath(locale, '/components/')}'`}>{t(locale, 'home.openComponents')}</nami-button>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="primary">03</nami-badge>
        <h3>{t(locale, 'nav.theme')}</h3>
        <p>{t(locale, 'home.pathThemeCopy')}</p>
        <nami-button variant="soft" onclick={`location.href='${localizedPath(locale, '/theme/')}'`}>{t(locale, 'nav.theme')}</nami-button>
      </nami-card>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{locale === 'zh-CN' ? '社区' : 'Community'}</p>
      <h2>{locale === 'zh-CN' ? '贡献者、仓库与赞助商' : 'Contributors, Repository, and Sponsors'}</h2>
      <p>{locale === 'zh-CN' ? '这里只展示当前仓库可验证的数据，不虚构赞助商或生态链接。' : 'This area only shows verifiable repository data and does not invent sponsors or ecosystem links.'}</p>
    </div>
    <div class="entry-grid">
      <nami-card>
        <nami-badge slot="header" variant="primary">{locale === 'zh-CN' ? '贡献者' : 'Contributor'}</nami-badge>
        <h3><a href={primaryContributor.url} target="_blank" rel="noreferrer">{primaryContributor.name}</a></h3>
        <p>{locale === 'zh-CN' ? '当前仓库贡献者。' : 'Current repository contributor.'}</p>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="primary">{locale === 'zh-CN' ? '仓库' : 'Repository'}</nami-badge>
        <h3><a href={projectInfo.repositoryUrl} target="_blank" rel="noreferrer">{projectInfo.repositoryLabel}</a></h3>
        <p>{locale === 'zh-CN' ? '公开仓库与问题追踪入口。' : 'Public repository and issue-tracking entry.'}</p>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="warning">{locale === 'zh-CN' ? '赞助商' : 'Sponsors'}</nami-badge>
        <h3>{projectInfo.sponsorStatus[locale]}</h3>
        <p>{locale === 'zh-CN' ? '没有真实数据源前，官网不会展示假赞助商。' : 'The docs will not display fake sponsors without a real data source.'}</p>
      </nami-card>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{t(locale, 'nav.theme')}</p>
      <h2>{t(locale, 'home.vibeTitle')}</h2>
      <p>{t(locale, 'home.vibeCopy')}</p>
    </div>
    <div class="style-split">
      <div class="theme-contract-stage" data-nami-theme="light" data-nami-style="default">
        <h3>Default</h3>
        <nami-button>Save</nami-button>
        <nami-chip selected>Selected</nami-chip>
        <nami-input label="Project" placeholder="Nami UI"></nami-input>
      </div>
      <div class="theme-contract-stage nami-theme-illustration" data-nami-theme="light" data-nami-style="illustration">
        <h3>Illustration</h3>
        <nami-button>Save</nami-button>
        <nami-chip selected>Selected</nami-chip>
        <nami-input label="Project" placeholder="Nami UI"></nami-input>
      </div>
    </div>
  </section>
</DocsLayout>
