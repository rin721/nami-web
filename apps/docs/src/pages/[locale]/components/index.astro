---
import DocsLayout from '../../../components/DocsLayout.astro';
import {
  componentCatalogItemsForGroup,
  componentPath,
  componentGroups,
  groupDescription,
  groupTitle
} from '../../../lib/catalog';
import { docsLocales, type DocsLocale } from '../../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
const labels = locale === 'zh-CN'
  ? {
      title: '组件总览',
      eyebrow: 'Components',
      description: 'Nami UI 组件按界面任务分组展示。已实现组件可以进入参考页；规划中组件只展示路线状态，不生成假 API。',
      search: '搜索组件',
      searchPlaceholder: '搜索组件名、用途或状态',
      available: '可用',
      planned: '规划中',
      emptyTitle: '没有匹配组件',
      emptyDescription: '换一个组件名、中文关键词或状态试试。'
    }
  : {
      title: 'Components Overview',
      eyebrow: 'Components',
      description: 'Nami UI components are grouped by interface task. Available components link to references; planned components show roadmap status only.',
      search: 'Search components',
      searchPlaceholder: 'Search name, use case, or status',
      available: 'Available',
      planned: 'Planned',
      emptyTitle: 'No matching components',
      emptyDescription: 'Try another component name, keyword, or status.'
    };
const groups = componentGroups.map((group) => ({
  group,
  items: componentCatalogItemsForGroup(group.id)
}));
---

<DocsLayout locale={locale} title={labels.title} description={labels.description}>
  <nami-docs-component-search id="component-docs" class="component-overview-shell">
    <aside class="component-overview-sidebar" aria-label={labels.title}>
      <a class="component-overview-home" href="#component-overview-top" aria-current="page">{labels.title}</a>
      <nav class="component-overview-index">
        {groups.map(({ group, items }) => (
          <section>
            <a class="component-overview-group-link" href={`#${group.id}`}>
              <span>{groupTitle(group, locale)}</span>
              <small>{items.length}</small>
            </a>
            <div class="component-overview-item-links">
              {items.map((item) => item.status === 'available' ? (
                <a href={componentPath(locale, item.name)}>
                  <span>{item.displayName[locale]}</span>
                  <small>{locale === 'zh-CN' ? item.displayName['en-US'] : item.name}</small>
                </a>
              ) : (
                <span class="component-overview-planned-link" aria-disabled="true">
                  <span>{item.displayName[locale]}</span>
                  <small>{labels.planned}</small>
                </span>
              ))}
            </div>
          </section>
        ))}
      </nav>
    </aside>

    <main class="component-overview-main" id="component-overview-top">
      <header class="component-overview-header">
        <p class="eyebrow">{labels.eyebrow}</p>
        <h1>{labels.title}</h1>
        <p>{labels.description}</p>
      </header>

      <label class="component-search">
        <span>{labels.search}</span>
        <input data-component-search-input type="search" placeholder={labels.searchPlaceholder} autocomplete="off" />
      </label>

      <div class="component-overview-sections">
        {groups.map(({ group, items }) => (
          <section class="component-overview-section" id={group.id} data-component-section>
            <header class="component-overview-section-header">
              <div>
                <h2>{groupTitle(group, locale)}</h2>
                <p>{groupDescription(group, locale)}</p>
              </div>
              <span>{items.length}</span>
            </header>
            <div class="component-section-grid">
              {items.map((item) => {
                const statusLabel = item.status === 'available' ? labels.available : labels.planned;
                const search = [
                  item.name,
                  item.displayName['zh-CN'],
                  item.displayName['en-US'],
                  item.useCase['zh-CN'],
                  item.useCase['en-US'],
                  item.status,
                  statusLabel,
                  ...item.keywords
                ].join(' ');
                const cardContent = (
                  <>
                    <header>
                      <strong>{item.displayName[locale]}</strong>
                      <nami-badge variant={item.status === 'available' ? 'primary' : 'warning'} tone="soft">{statusLabel}</nami-badge>
                    </header>
                    <div class="component-overview-preview" set:html={item.preview}></div>
                    <p>{item.useCase[locale]}</p>
                  </>
                );
                return item.status === 'available' ? (
                  <a
                    class="component-overview-card"
                    href={componentPath(locale, item.name)}
                    data-component-card={item.name}
                    data-status={item.status}
                    data-search={search}
                  >
                    {cardContent}
                  </a>
                ) : (
                  <article
                    class="component-overview-card is-planned"
                    data-component-card={item.name}
                    data-status={item.status}
                    data-search={search}
                    aria-disabled="true"
                  >
                    {cardContent}
                  </article>
                );
              })}
            </div>
          </section>
        ))}
      </div>

      <nami-empty class="component-search-empty" data-component-empty hidden title={labels.emptyTitle} description={labels.emptyDescription} compact></nami-empty>
    </main>
  </nami-docs-component-search>
</DocsLayout>
