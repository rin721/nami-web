---
import DocsLayout from '../../../components/DocsLayout.astro';
import { componentGroups, componentPath, componentPreviews, componentUseCase, groupDescription, groupTitle, metadataByName, namiComponentMetadata } from '../../../lib/catalog';
import { docsLocales, t, type DocsLocale } from '../../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
const componentCount = namiComponentMetadata.length;
const tokenCount = namiComponentMetadata.reduce((count, item) => count + item.tokens.length, 0);
---

<DocsLayout locale={locale} title={t(locale, 'nav.components')}>
  <section class="section component-directory">
    <div class="section-heading">
      <p class="eyebrow">{t(locale, 'nav.components')}</p>
      <h1>{t(locale, 'components.title')}</h1>
      <p>{t(locale, 'components.copy')}</p>
    </div>

    <div class="entry-grid">
      <nami-card>
        <nami-badge slot="header" variant="primary">{locale === 'zh-CN' ? '这里放什么' : 'What lives here'}</nami-badge>
        <p>{locale === 'zh-CN' ? '组件目录只放可实例化组件、组件任务分组和组件详情入口。' : 'The component directory only contains instantiable components, task groups, and reference entries.'}</p>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="primary">{locale === 'zh-CN' ? '不放什么' : 'What stays out'}</nami-badge>
        <p>{locale === 'zh-CN' ? '主题教程、质量规范、i18n 说明和站点设置不放在组件页。' : 'Theme tutorials, quality guidance, i18n notes, and site settings stay out of component pages.'}</p>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="primary">{locale === 'zh-CN' ? '下一步去哪' : 'Where next'}</nami-badge>
        <p>{locale === 'zh-CN' ? '选定组件后进入详情页查看 API、slots、parts、states、tokens 和语义结构。' : 'Open a component page for APIs, slots, parts, states, tokens, and anatomy.'}</p>
      </nami-card>
    </div>

    <div class="directory-stats">
      <nami-card>
        <nami-badge slot="header" variant="primary">{componentCount}</nami-badge>
        <h3>{t(locale, 'components.statsComponents')}</h3>
        <p>{t(locale, 'components.statsComponentsCopy')}</p>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="primary">{componentGroups.length}</nami-badge>
        <h3>{t(locale, 'components.statsGroups')}</h3>
        <p>{t(locale, 'components.statsGroupsCopy')}</p>
      </nami-card>
      <nami-card>
        <nami-badge slot="header" variant="primary">{tokenCount}</nami-badge>
        <h3>{t(locale, 'components.statsTokens')}</h3>
        <p>{t(locale, 'components.statsTokensCopy')}</p>
      </nami-card>
    </div>

    <div id="component-docs" class="component-docs">
      {componentGroups.map((group) => (
        <section class="component-group" id={group.id}>
          <div class="component-group-heading">
            <div>
              <h3>{groupTitle(group, locale)}</h3>
              <p>{groupDescription(group, locale)}</p>
            </div>
            <nami-badge>{group.names.length} items</nami-badge>
          </div>
          <div class="component-group-grid">
            {group.names.map((name) => {
              const item = metadataByName.get(name);
              if (!item) return null;
              return (
                <nami-card data-component-card={item.name}>
                  <div class="component-preview" set:html={componentPreviews.get(item.name) ?? item.usage} />
                  <div class="component-copy">
                    <nami-badge slot="header" variant="primary">{item.name}</nami-badge>
                    <h3>{item.name}</h3>
                    <p>{componentUseCase(item.name, locale)}</p>
                    <div class="component-card-meta">
                      <nami-badge>{item.events.length} events</nami-badge>
                      <nami-badge>{item.parts.length} parts</nami-badge>
                      <nami-badge>{item.tokens.length} tokens</nami-badge>
                    </div>
                    <nami-button variant="soft" onclick={`location.href='${componentPath(locale, item.name)}'`}>{t(locale, 'component.open')}</nami-button>
                  </div>
                </nami-card>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </section>
</DocsLayout>
