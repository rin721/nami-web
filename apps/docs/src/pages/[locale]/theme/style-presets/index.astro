---
import DocsLayout from '../../../../components/DocsLayout.astro';
import { docsLocales, t, type DocsLocale } from '../../../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
---

<DocsLayout locale={locale} title={t(locale, 'theme.presetsTitle')}>
  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{t(locale, 'nav.theme')}</p>
      <h1>{t(locale, 'theme.presetsTitle')}</h1>
      <p>{t(locale, 'theme.presetsCopy')}</p>
    </div>

    <div class="theme-contract-grid">
      <div class="theme-contract-stage" data-contract-stage="default-light" data-rl-theme="light" data-rl-style="default">
        <h3>Default / Light</h3>
        <rl-button>Save</rl-button>
        <rl-chip selected>Ready</rl-chip>
        <rl-input label="Name" placeholder="Project"></rl-input>
      </div>
      <div class="theme-contract-stage" data-contract-stage="default-dark" data-rl-theme="dark" data-rl-style="default">
        <h3>Default / Dark</h3>
        <rl-button>Save</rl-button>
        <rl-chip selected>Ready</rl-chip>
        <rl-input label="Name" placeholder="Project"></rl-input>
      </div>
      <div class="theme-contract-stage rl-theme-illustration" data-contract-stage="illustration-light" data-rl-theme="light" data-rl-style="illustration">
        <h3>Illustration / Light</h3>
        <rl-button>Save</rl-button>
        <rl-chip selected>Ready</rl-chip>
        <rl-input label="Name" placeholder="Project"></rl-input>
      </div>
      <div class="theme-contract-stage rl-theme-illustration" data-contract-stage="illustration-dark" data-rl-theme="dark" data-rl-style="illustration">
        <h3>Illustration / Dark</h3>
        <rl-button>Save</rl-button>
        <rl-chip selected>Ready</rl-chip>
        <rl-input label="Name" placeholder="Project"></rl-input>
      </div>
    </div>

    <rl-card>
      <h3 slot="header">{locale === 'zh-CN' ? '设计原则' : 'Design principle'}</h3>
      <p>{locale === 'zh-CN' ? '风格预设只改变 token 与组件样式边界，不复制组件源码，也不创建 rl-ant-button 这类重复组件。' : 'Style presets only change tokens and style boundaries. They do not duplicate component source or create parallel components such as rl-ant-button.'}</p>
    </rl-card>
  </section>
</DocsLayout>
