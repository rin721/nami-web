---
import DocsLayout from '../../../../components/DocsLayout.astro';
import { docsLocales, t, type DocsLocale } from '../../../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
---

<DocsLayout locale={locale} title={t(locale, 'theme.presetsTitle')}>
  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{t(locale, 'nav.theme')}</p>
      <h1>{t(locale, 'theme.presetsTitle')}</h1>
      <p>{t(locale, 'theme.presetsCopy')}</p>
    </div>

    <div class="theme-contract-grid">
      <div class="theme-contract-stage" data-contract-stage="default-light" data-nami-theme="light" data-nami-style="default">
        <h3>Default / Light</h3>
        <nami-button>Save</nami-button>
        <nami-chip selected>Ready</nami-chip>
        <nami-input label="Name" placeholder="Project"></nami-input>
      </div>
      <div class="theme-contract-stage" data-contract-stage="default-dark" data-nami-theme="dark" data-nami-style="default">
        <h3>Default / Dark</h3>
        <nami-button>Save</nami-button>
        <nami-chip selected>Ready</nami-chip>
        <nami-input label="Name" placeholder="Project"></nami-input>
      </div>
      <div class="theme-contract-stage nami-theme-illustration" data-contract-stage="illustration-light" data-nami-theme="light" data-nami-style="illustration">
        <h3>Illustration / Light</h3>
        <nami-button>Save</nami-button>
        <nami-chip selected>Ready</nami-chip>
        <nami-input label="Name" placeholder="Project"></nami-input>
      </div>
      <div class="theme-contract-stage nami-theme-illustration" data-contract-stage="illustration-dark" data-nami-theme="dark" data-nami-style="illustration">
        <h3>Illustration / Dark</h3>
        <nami-button>Save</nami-button>
        <nami-chip selected>Ready</nami-chip>
        <nami-input label="Name" placeholder="Project"></nami-input>
      </div>
    </div>

    <nami-card>
      <h3 slot="header">{locale === 'zh-CN' ? '设计原则' : 'Design principle'}</h3>
      <p>{locale === 'zh-CN' ? '风格预设只改变 token 与组件样式边界，不复制组件源码，也不创建 nami-ant-button 这类重复组件。' : 'Style presets only change tokens and style boundaries. They do not duplicate component source or create parallel components such as nami-ant-button.'}</p>
    </nami-card>
  </section>
</DocsLayout>
