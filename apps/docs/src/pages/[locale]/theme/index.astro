---
import DocsArticleLayout from '../../../components/DocsArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { adjacentDocsEntries, docsSections } from '../../../lib/docs-structure';
import { docsLocales, normalizeDocsLocale, type DocsLocale } from '../../../lib/site';

export function getStaticPaths() {
  return docsLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: DocsLocale };
const section = docsSections.theme;
const entries = await getCollection('theme');
const overview = entries.find((entry) => {
  const [localeId, slug] = entry.id.replace(/\.(md|mdx)$/, '').split('/');
  return normalizeDocsLocale(localeId) === locale && slug === 'overview';
});

if (!overview) {
  throw new Error(`Missing theme overview content for ${locale}`);
}

const { Content, headings } = await render(overview);
const adjacent = adjacentDocsEntries('theme', 'overview');
const navGroups = [{
  title: section.title[locale],
  items: section.entries.map((item) => ({
    label: item.title[locale],
    href: item.path,
    description: item.description[locale]
  }))
}];
---

<DocsArticleLayout
  locale={locale}
  title={overview.data.title}
  description={overview.data.description ?? section.entries[0].description[locale]}
  eyebrow={section.title[locale]}
  currentPath={section.path}
  navGroups={navGroups}
  headings={headings}
  next={adjacent.next && { label: adjacent.next.title[locale], href: adjacent.next.path }}
>
  <Content />
</DocsArticleLayout>
