---
import '../../../../../packages/core/src/critical.css';
import '../../../../../packages/themes/src/default.css';
import '../../../../../packages/themes/src/ant-illustration.css';
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nami Critical Fixture</title>
    <script>
      import '../../scripts/register-nami.ts';
    </script>
  </head>
  <body>
    <nami-theme theme="light" accent="#3b82f6" density="comfortable" motion="normal" style-preset="default">
      <nami-page-transition id="fixture-transition" appearance="veil" active>
        <span data-nami-transition-fallback>
          <svg
            class="nami-mark"
            viewBox="291 222 660 801"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
          >
            <path
              class="nami-mark-main"
              d="M292 349 L291 850 L422 850 L423 535 L680 850 L651 1023 L767 1023 L931 349 L764 350 L709 671 L455 349 Z"
            />
            <path class="nami-mark-dots" d="M749 222 L826 222 L815 317 L767 317 Z" />
            <path class="nami-mark-dots" d="M874 222 L951 222 L931 317 L882 317 Z" />
          </svg>
          <span aria-hidden="true"></span>
        </span>
      </nami-page-transition>
      <nami-app-shell>
        <nav slot="rail" class="rail-stack" aria-label="Primary">
          <a href="/fixtures/nami-critical/" aria-current="page" aria-label="Home" data-label="Home">H</a>
        </nav>
        <div slot="top" class="mobile-bar">
          <a class="brand-link" href="/fixtures/nami-critical/">Nami UI</a>
        </div>
        <nav slot="bottom" class="bottom-nav" aria-label="Mobile">
          <a href="/fixtures/nami-critical/" aria-current="page">Home</a>
        </nav>
        <main class="docs-page">
          <section class="hero">
            <div class="hero-copy">
              <p class="eyebrow">Fixture</p>
              <h1>Nami UI</h1>
              <p class="hero-subtitle">Critical CSS without the Astro client router.</p>
              <div class="hero-actions">
                <nami-button>Primary</nami-button>
                <nami-chip checkbox selected>Selected</nami-chip>
              </div>
            </div>
          </section>
        </main>
      </nami-app-shell>
    </nami-theme>
  </body>
</html>
