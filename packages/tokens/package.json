{
  "name": "@nami-web/tokens",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "default": "./dist/theme.js"
    },
    "./theme-studio": {
      "types": "./dist/theme-studio.d.ts",
      "default": "./dist/theme-studio.js"
    },
    "./tokens.dtcg.json": "./dist/tokens.dtcg.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "test": "vitest run"
  }
}
