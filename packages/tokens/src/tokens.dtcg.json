{
  "$schema": "https://www.designtokens.org/schemas/2025.10/tokens.json",
  "seed": {
    "accent": {
      "50": {
        "$type": "color",
        "$value": "#3b82f6"
      }
    },
    "radius": {
      "control": {
        "$type": "dimension",
        "$value": "999px"
      },
      "surface": {
        "$type": "dimension",
        "$value": "6px"
      }
    },
    "motion": {
      "fast": {
        "$type": "duration",
        "$value": "120ms"
      },
      "normal": {
        "$type": "duration",
        "$value": "250ms"
      },
      "exit": {
        "$type": "duration",
        "$value": "150ms"
      }
    },
    "style": {
      "strokeWidth": {
        "$type": "dimension",
        "$value": "1px"
      },
      "strokeColor": {
        "$type": "color",
        "$value": "{semantic.color.border}"
      },
      "inkColor": {
        "$type": "color",
        "$value": "{semantic.color.text}"
      },
      "onPaper": {
        "$type": "color",
        "$value": "{semantic.color.text}"
      },
      "onPaperMuted": {
        "$type": "color",
        "$value": "{semantic.color.textMuted}"
      },
      "offsetShadow": {
        "$type": "shadow",
        "$value": "none"
      },
      "controlBg": {
        "$type": "color",
        "$value": "transparent"
      },
      "panelBg": {
        "$type": "color",
        "$value": "{semantic.color.surface}"
      },
      "paperBg": {
        "$type": "color",
        "$value": "#fff7fb"
      },
      "borderRadius": {
        "$type": "dimension",
        "$value": "{seed.radius.surface}"
      },
      "backgroundPattern": {
        "$type": "string",
        "$value": "none"
      },
      "doodleOpacity": {
        "$type": "number",
        "$value": 0
      },
      "paperLineColor": {
        "$type": "color",
        "$value": "{semantic.color.border}"
      },
      "focusShadow": {
        "$type": "shadow",
        "$value": "{semantic.focus.ring}"
      }
    }
  },
  "semantic": {
    "color": {
      "primary": {
        "$type": "color",
        "$value": "{seed.accent.50}"
      },
      "surface": {
        "$type": "color",
        "$value": "#ffffff"
      },
      "text": {
        "$type": "color",
        "$value": "#171717"
      },
      "textMuted": {
        "$type": "color",
        "$value": "#666b74"
      },
      "border": {
        "$type": "color",
        "$value": "rgba(0, 0, 0, 0.12)"
      },
      "overlayBackdrop": {
        "$type": "color",
        "$value": "rgba(0, 0, 0, 0.48)"
      }
    },
    "focus": {
      "ring": {
        "$type": "shadow",
        "$value": "0 0 0 3px rgba(59, 130, 246, 0.38)"
      }
    }
  },
  "component": {
    "button": {
      "bg": {
        "$type": "color",
        "$value": "{semantic.color.primary}"
      }
    },
    "card": {
      "bg": {
        "$type": "color",
        "$value": "{semantic.color.surface}"
      },
      "fg": {
        "$type": "color",
        "$value": "{semantic.color.text}"
      },
      "border": {
        "$type": "color",
        "$value": "{semantic.color.border}"
      },
      "shadow": {
        "$type": "shadow",
        "$value": "none"
      }
    },
    "badge": {
      "bg": {
        "$type": "color",
        "$value": "rgba(0, 0, 0, 0.05)"
      },
      "fg": {
        "$type": "color",
        "$value": "{semantic.color.text}"
      },
      "border": {
        "$type": "color",
        "$value": "transparent"
      }
    },
    "radioCard": {
      "selectedShadow": {
        "$type": "shadow",
        "$value": "0 0 0 1px {semantic.color.primary}, {semantic.focus.ring}"
      }
    },
    "switch": {
      "thumbBg": {
        "$type": "color",
        "$value": "{semantic.color.surface}"
      },
      "thumbShadow": {
        "$type": "shadow",
        "$value": "0 1px 4px rgba(0, 0, 0, 0.24)"
      }
    },
    "softControl": {
      "color": {
        "$type": "color",
        "$value": "{semantic.color.text}"
      }
    },
    "spinner": {
      "trackColor": {
        "$type": "color",
        "$value": "rgba(0, 0, 0, 0.28)"
      }
    },
    "illustration": {
      "primary": {
        "$type": "color",
        "$value": "{semantic.color.primary}"
      },
      "secondary": {
        "$type": "color",
        "$value": "#8ec5ff"
      },
      "line": {
        "$type": "color",
        "$value": "#5b6472"
      }
    }
  }
}
