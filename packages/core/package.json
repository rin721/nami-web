{
  "name": "@nami-web/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "default": "./dist/register.js"
    },
    "./themes": {
      "types": "./dist/themes.d.ts",
      "default": "./dist/themes.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "default": "./dist/metadata.js"
    },
    "./anatomy": {
      "types": "./dist/anatomy.d.ts",
      "default": "./dist/anatomy.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "default": "./dist/catalog.js"
    },
    "./nami-ui.anatomy.json": "./dist/nami-ui.anatomy.json",
    "./nami-ui.theme.schema.json": "./dist/nami-ui.theme.schema.json",
    "./critical.css": "./dist/critical.css",
    "./localize": {
      "types": "./dist/localize.d.ts",
      "default": "./dist/localize.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./*/register": {
      "types": "./dist/register/*.d.ts",
      "default": "./dist/register/*.js"
    },
    "./*": {
      "types": "./dist/register/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly && node ./scripts/write-machine-readable.mjs && node ./scripts/copy-css.mjs",
    "build:cdn": "vite build -c vite.cdn.config.ts --mode cdn-global && vite build -c vite.cdn.config.ts --mode cdn-esm && node ./scripts/copy-cdn-assets.mjs",
    "manifest": "cem analyze --litelement --globs \"src/**/*.ts\" --outdir dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@lit/localize": "^0.12.2",
    "@nami-web/themes": "0.1.0",
    "@nami-web/tokens": "0.1.0",
    "lenis": "1.3.23",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0"
  },
  "customElements": "dist/custom-elements.json"
}
